[[phase]]
id = "P-003-1"
title = "Review gate + toml creation + parser prep"
status = "pending"
[[phase]]
id = "P-003-2"
title = "Implement openable + updates"
status = "pending"
tasks = ["Create messages.toml with [[message]] (from old, minus 1).", "Update types + config parser to load messages (add to WebConfig or export).", "After gate: update messages page to load 1 + others from config.", "Enhance MessageList for openable (e.g. selected state, onClick opens expanded div or simple modal with full text larger font, close, anim).", "Verify load, open works, build."]
verification = ["toml present", "parser works", "page shows 1 + loads, clicking opens detail nicely", "build 0"]

[progress]
