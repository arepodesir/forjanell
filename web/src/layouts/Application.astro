---
import '@/css/global.css';

import Head from "@/includes/Head/Head.astro"

let head = Astro.props
---

<!DOCTYPE html>
<html lang="en">
<Head title={head.title} subTitle={head.subTitle}/>
  <body class="relative min-h-screen">
    <slot/>

    <script is:inline>
      (function() {
        const pathname = window.location.pathname;
        // Gift pages (hadacard visual novel, circa-1993 end scenes, etc.) fully own their audio.
        // Prevents the global BGM from restarting on interactions and overlapping scene music (sfxHbd + end song).
        const isAudioOwnedPage = pathname.startsWith('/gifts/');

        // Create or retrieve single global BGM instance (still used by MusicTitlebar and scenes for coordination)
        let audio = window.globalBgmAudio;
        if (!audio) {
          audio = new Audio('/resources/sfx/hbd.mp3');
          audio.loop = true;
          audio.volume = 0.3;
          window.globalBgmAudio = audio;

          // Restore playback position (time persistence kept for continuity)
          const savedTime = sessionStorage.getItem('bgm_currentTime');
          if (savedTime) {
            audio.currentTime = parseFloat(savedTime);
          }
        }

        // Periodically persist current time
        setInterval(() => {
          if (audio && !audio.paused) {
            sessionStorage.setItem('bgm_currentTime', audio.currentTime.toString());
          }
        }, 500);

        if (isAudioOwnedPage) {
          // Gift / visual novel pages (circa-1993 etc.) take full audio control.
          // Their local players (sfxHbd, end song via MusicTitlebar) manage playback.
          if (audio) {
            audio.pause();
          }
          return;
        }

        // Play global BGM on first user interaction (no mute control remains)
        function startAudio() {
          if (audio.paused) {
            audio.play().catch(e => console.log('Autoplay deferred:', e));
          }
          document.removeEventListener('click', startAudio);
          document.removeEventListener('keydown', startAudio);
          document.removeEventListener('touchstart', startAudio);
        }

        document.addEventListener('click', startAudio);
        document.addEventListener('keydown', startAudio);
        document.addEventListener('touchstart', startAudio);
      })();
    </script>
  </body>
</html>
