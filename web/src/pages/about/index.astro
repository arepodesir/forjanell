---
import Application from '../../layouts/Application.astro'
import Container from '../../layouts/Container.astro'
import BackButton from '@/components/Navigator/BackButton'
---

<Application title="For Janell" subTitle=" | About">
  <Container>


    {/* Floating Back to Home button (solid, type-safe) */}
    <BackButton client:load to="/" label="Back Home" emoji="🏠" />

    <div class="relative z-10 w-full max-w-lg aero-glass rounded-3xl p-6 text-white mt-16 animate-reveal-up border-white/20 shadow-2xl">
      <div class="flex flex-col items-center gap-6">
        
        {/* Profile Picture Frame */}
        <div class="relative w-36 h-36 shrink-0 animate-float" id="avatar-frame">
          <div class="w-full h-full rounded-full border-4 border-aero-cyan overflow-hidden"
               style="box-shadow: 0 0 20px rgba(0,243,255,0.6), 0 0 40px rgba(188,19,254,0.3);">
            <img src="/resources/img/janell.png" alt="Janell" class="w-full h-full object-cover" />
          </div>
          <span class="absolute -bottom-1 -right-1 bg-gradient-to-r from-aero-pink to-aero-cyan text-white text-[10px] font-extrabold px-3 py-1 rounded-full border border-white/40 shadow-lg">
            ★ MVP
          </span>
        </div>

        {/* Profile Details */}
        <div class="w-full text-center">
          <h1 class="text-3xl font-extrabold mb-1 tracking-wide" style="font-family: 'Caveat', cursive;">
            Janell Hill-Bridget
          </h1>
          <p class="text-aero-cyan font-bold text-xs mb-4 tracking-wider uppercase" style="font-family: 'Comfortaa', sans-serif;">
            ✦ Quantum Birthday Recipient ✦
          </p>
          <div class="grid grid-cols-2 gap-3 text-left text-xs font-semibold bg-black/20 p-4 rounded-xl border border-white/10" style="font-family: 'Patrick Hand', cursive;">
            <div>
              <span class="text-white/50 block text-[9px] font-mono">ZODIAC</span>
              <span class="text-white font-bold">Taurus ♉</span>
            </div>
            <div>
              <span class="text-white/50 block text-[9px] font-mono">RARITY</span>
              <span class="text-aero-pink font-bold">✦ Ultra Rare Holo</span>
            </div>
            <div>
              <span class="text-white/50 block text-[9px] font-mono">EDITION</span>
              <span class="text-white font-bold">2026 Edition</span>
            </div>
            <div>
              <span class="text-white/50 block text-[9px] font-mono">CARD ID</span>
              <span class="text-aero-cyan font-bold">HC-001</span>
            </div>
          </div>
        </div>
      </div>

      <hr class="border-white/10 my-5" />

      {/* Bio & Attributes */}
      <div class="space-y-4 text-sm leading-relaxed" style="font-family: 'Patrick Hand', cursive;">
        <h2 class="text-xl font-bold text-aero-cyan" style="font-family: 'Comfortaa', sans-serif;">
          Bio & Attributes 💎
        </h2>
        <p class="text-blue-100/90 font-medium">
          Janell is a legendary individual, known across multiple servers and quantum realms for her dazzling aura, stellar fashion sense, and crystal-clear energy. This card represents a yearly extraction from the friendship field, designed to celebrate another year of her amazing existence!
        </p>
        <p class="text-blue-100/90 font-medium">
          She is certified 100% awesome, immune to bad vibes, and possesses a passive skill: <strong class="text-aero-pink">Instant Sparkle</strong>, which automatically brightens up any room she walks into. ✨
        </p>
      </div>

      {/* Attributes Bar */}
      <div class="mt-6 space-y-2">
        <div class="flex justify-between text-[10px] font-mono">
          <span>SPARKLE LEVEL</span>
          <span class="text-aero-cyan font-bold">OVER 9000</span>
        </div>
        <div class="w-full bg-white/10 h-3 rounded-full overflow-hidden p-0.5 border border-white/10" id="sparkle-bar">
          <div class="h-full bg-gradient-to-r from-aero-cyan to-aero-pink rounded-full animate-shimmer" style="width: 100%; background-size: 200% 100%;"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { haptic } from '../../utils/haptics';

    const avatar = document.getElementById('avatar-frame');
    const sparkle = document.getElementById('sparkle-bar');

    if (avatar) {
      avatar.addEventListener('pointerdown', () => haptic.trigger('success'));
    }
    if (sparkle) {
      sparkle.addEventListener('pointerdown', () => haptic.trigger('medium'));
    }
  </script>
  </Container>
</Application>
