---
import Application from '../../layouts/Application.astro'
import Container from '../../layouts/Container.astro'
import BackButton from '@/components/Navigator/BackButton'
---

<Application title="For Janell" subTitle=" | About">
  <Container>


    {/* Floating Back to Home button (solid, type-safe) */}
    <BackButton client:load to="/" label="Back Home" emoji="🏠" />

    <div class="relative z-10 w-full max-w-lg aero-glass rounded-3xl p-6 text-white mt-16 animate-reveal-up border-white/20 shadow-2xl">
      {/* App-focused header */}
      <div class="text-center mb-6">
        <h1 class="text-3xl font-extrabold mb-2 tracking-wide" style="font-family: 'Caveat', cursive;">
          The Experience
        </h1>
        <p class="text-aero-cyan text-xs tracking-wider uppercase font-bold" style="font-family: 'Comfortaa', sans-serif;">
          An Interactive Holographic Love Letter
        </p>
      </div>

      <p class="text-blue-100/90 text-sm leading-relaxed mb-5" style="font-family: 'Patrick Hand', cursive;">
        A living, responsive gift. A 3D card that tilts and shimmers under your fingers. Scenes that pop into a real interactive orchid. Music that feels present in the room. Particles that dance with your touch. This is a small digital world built to feel hand-written, intimate, and magical — the kind of thing you might keep on a shelf and open again on quiet nights.
      </p>

      <p class="text-blue-100/80 text-sm mb-6" style="font-family: 'Patrick Hand', cursive;">
        Made as a personal gift for Janell, inspired by the quiet power of physical objects (holographic cards, living orchids, music that carries memory) and the joy of crafting something in code that still feels like a letter from one person to another.
      </p>

      <hr class="border-white/10 my-5" />

      {/* Fun well-made live-updating README-style content */}
      <div class="space-y-6 text-sm leading-relaxed" style="font-family: 'Patrick Hand', cursive;">
        <div>
          <h2 class="text-lg font-bold text-aero-cyan mb-2" style="font-family: 'Comfortaa', sans-serif;">What This Is</h2>
          <p class="text-blue-100/90">
            A collection of small, deliberate moments: the Hadacard (a holographic letter that opens to your touch), FrutigerScenes (a gentle visual novel that ends in a living 3D orchid), a music titlebar that feels like an old cassette, and responsive particles that make the space feel alive.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-aero-cyan mb-2" style="font-family: 'Comfortaa', sans-serif;">The Living Letter</h2>
          <p class="text-blue-100/90">
            The card responds to pointer and touch with real-time holographic foil, glitter, and gentle 3D tilt. It can be "closed" or opened wide into landscape. Every element (profile, candles, flowing text) is there to make it feel like a real object you are holding.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-bold text-aero-cyan mb-2" style="font-family: 'Comfortaa', sans-serif;">How the Magic is Made</h2>
          <p class="text-blue-100/90 mb-2">
            Built with Astro for the quiet shell + Solid for the living parts, Three.js for the orchid, careful audio handoff, and a lot of love for glassmorphism, haptics, and handwriting fonts.
          </p>
          <div class="text-[10px] text-white/60 font-mono bg-black/20 p-2 rounded border border-white/10">
            Tech: Astro • SolidJS • Three.js • Tailwind • Love
          </div>
        </div>
      </div>

      {/* Live updating README section — fun & interactive */}
      <div class="mt-6 pt-5 border-t border-white/10">
        <h2 class="text-lg font-bold text-aero-cyan mb-3" style="font-family: 'Comfortaa', sans-serif;">
          Live Reactions
        </h2>

        <div id="sparks-container" class="aero-glass rounded-2xl p-4 mb-3 border border-white/10">
          <div class="flex items-baseline justify-between">
            <span class="text-white/70 text-xs tracking-wider uppercase">Sparks Shared</span>
            <span id="sparks-count" class="text-2xl font-bold text-aero-pink tabular-nums">142</span>
          </div>
          <p class="text-[10px] text-white/50 mt-1">Tap to add one. It only lives here for you.</p>
        </div>

        <button id="send-spark"
                class="w-full aero-glass active:scale-[0.985] transition-all rounded-full py-2.5 text-sm font-semibold tracking-wider border border-white/20 hover:border-aero-pink/40">
          ✨ Send a Spark
        </button>

        <div class="mt-4 text-[10px] text-white/50 text-center" style="font-family: 'Comfortaa', sans-serif;">
          Last unfolded just now • The letter is still warm
        </div>
      </div>

      {/* Ko-fi ask with brand button */}
      <div class="mt-8 pt-5 border-t border-white/10 text-center">
        <p class="text-xs text-white/70 mb-3" style="font-family: 'Comfortaa', sans-serif;">
          If this little world brought you a smile, you can keep the magic going.
        </p>

        <a href="https://ko-fi.com/whoisarepo"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-[#FF5E5B] hover:bg-[#e44d4a] active:scale-[0.985] transition-all text-white text-sm font-bold tracking-wider shadow-md border border-white/30">
          ☕ Support @whoisarepo on Ko-fi
        </a>

        <p class="mt-2 text-[10px] text-white/50" style="font-family: 'Comfortaa', sans-serif;">
          Built with love by @whoisarepo
        </p>
      </div>
    </div>
  </div>

  <script>
    import { haptic } from '../../utils/haptics';

    // Live updating "Sparks Shared" counter — fun, ephemeral, feels alive
    const sparksContainer = document.getElementById('sparks-container');
    const countEl = document.getElementById('sparks-count');
    const sendBtn = document.getElementById('send-spark');

    let sparks = 142;

    function updateCount(newVal) {
      sparks = newVal;
      if (countEl) {
        countEl.textContent = sparks;
        countEl.classList.add('scale-110', 'text-aero-cyan');
        setTimeout(() => {
          countEl && countEl.classList.remove('scale-110', 'text-aero-cyan');
        }, 180);
      }
    }

    if (sendBtn) {
      sendBtn.addEventListener('pointerdown', () => {
        haptic.trigger('success');
        updateCount(sparks + 1);
      });
    }

    if (sparksContainer) {
      sparksContainer.addEventListener('pointerdown', (e) => {
        if (e.target === sendBtn) return;
        haptic.trigger('light');
      });
    }

    // Gentle "live" touch feedback on the whole live section
    if (sparksContainer) {
      sparksContainer.addEventListener('pointerdown', () => {
        sparksContainer.classList.add('!border-aero-pink/40');
        setTimeout(() => {
          sparksContainer && sparksContainer.classList.remove('!border-aero-pink/40');
        }, 300);
      });
    }
  </script>
  </Container>
</Application>
