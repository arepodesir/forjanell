---
import Application from '../../layouts/Application.astro'
import MessageList from '../../components/MessageList'

const MESSAGES = [
  {
    sender: "Alice 💖",
    relation: "Best Friend",
    text: "Happy birthday Jell! Hope you have an amazing day filled with love, laughter, and endless sparkles. You deserve the absolute world! ✨",
    color: "border-aero-pink shadow-aero-pink/20",
    gradient: "from-pink-500/20 to-purple-500/20"
  },
  {
    sender: "Bob 🎨",
    relation: "Partner in Crime",
    text: "To the coolest Taurus I know: have a total blast! Keep shining bright and never stop being your fabulous, glittery self. Cheers to more adventures! 🥂",
    color: "border-aero-cyan shadow-aero-cyan/20",
    gradient: "from-cyan-500/20 to-blue-500/20"
  },
  {
    sender: "Clara 🦄",
    relation: "Soul Sister",
    text: "Janell, another year older, another year wiser, and another year of being completely iconic! Happy Birthday, gorgeous soul! 🎂🌸",
    color: "border-aero-magenta shadow-aero-magenta/20",
    gradient: "from-purple-500/20 to-pink-500/20"
  },
  {
    sender: "Dave 🚀",
    relation: "Tech Bro",
    text: "Sending you the biggest quantum holographic hug! May your day be filled with magic, code, coffee, and good vibes only. 💫",
    color: "border-aero-green shadow-aero-green/20",
    gradient: "from-green-500/20 to-teal-500/20"
  }
]

import Container from '../../layouts/Container.astro'
---

<Application title="For Janell" subTitle=" | Messages">
<Container>

    {/* Floating Back to Home button */}
    <a href="/" id="back-home-btn" class="absolute top-4 left-4 z-50 flex items-center gap-2 px-4 py-2 rounded-full aero-glass text-white font-bold text-sm transition-transform hover:scale-105 active:scale-95">
      🏠 Back Home
    </a>

    <div class="relative z-10 w-full max-w-lg text-center mt-16 mb-6">
      <h1 class="text-3xl font-extrabold text-white mb-2 tracking-wide drop-shadow-md" style="font-family: 'Caveat', cursive;">
        Messages for Janell 💌
      </h1>
      <p class="text-pink-200/80 text-xs tracking-wider uppercase font-extrabold animate-pulse" style="font-family: 'Comfortaa', sans-serif;">
        Words of Love & Celebration
      </p>
    </div>

    {/* Message list component (Client-side with Pretext line measurement and tactile/haptic features) */}
    <MessageList client:load messages={MESSAGES} />
  </div>

  <script>
    import { haptic } from '../../utils/haptics';
    const backBtn = document.getElementById('back-home-btn');
    if (backBtn) {
      backBtn.addEventListener('pointerdown', () => haptic.trigger('light'));
    }
  </script>
  </Container>
</Application>
