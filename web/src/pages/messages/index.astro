---
import Application from '../../layouts/Application.astro'

const MESSAGES = [
  {
    sender: "Alice 💖",
    relation: "Best Friend",
    text: "Happy birthday Jell! Hope you have an amazing day filled with love, laughter, and endless sparkles. You deserve the absolute world! ✨",
    color: "border-aero-pink shadow-aero-pink/20",
    gradient: "from-pink-500/20 to-purple-500/20"
  },
  {
    sender: "Bob 🎨",
    relation: "Partner in Crime",
    text: "To the coolest Taurus I know: have a total blast! Keep shining bright and never stop being your fabulous, glittery self. Cheers to more adventures! 🥂",
    color: "border-aero-cyan shadow-aero-cyan/20",
    gradient: "from-cyan-500/20 to-blue-500/20"
  },
  {
    sender: "Clara 🦄",
    relation: "Soul Sister",
    text: "Janell, another year older, another year wiser, and another year of being completely iconic! Happy Birthday, gorgeous soul! 🎂🌸",
    color: "border-aero-magenta shadow-aero-magenta/20",
    gradient: "from-purple-500/20 to-pink-500/20"
  },
  {
    sender: "Dave 🚀",
    relation: "Tech Bro",
    text: "Sending you the biggest quantum holographic hug! May your day be filled with magic, code, coffee, and good vibes only. 💫",
    color: "border-aero-green shadow-aero-green/20",
    gradient: "from-green-500/20 to-teal-500/20"
  }
]
---

<Application title="For Janell" subTitle=" | Messages">
  <div class="relative w-full h-full min-h-screen overflow-y-auto bg-cover bg-center flex flex-col items-center p-6"
       style="background-image: url('/resources/img/Hallway.png');">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-950/70 via-purple-950/60 to-black/80"></div>

    {/* Floating Back to Home button */}
    <a href="/" class="absolute top-4 left-4 z-50 flex items-center gap-2 px-4 py-2 rounded-full aero-glass text-white font-bold text-sm transition-transform hover:scale-105 active:scale-95">
      🏠 Back Home
    </a>

    <div class="relative z-10 w-full max-w-4xl text-center mt-12 mb-8">
      <h1 class="text-4xl font-extrabold text-white mb-2 tracking-wide drop-shadow-md" style="font-family: 'Outfit', sans-serif;">
        Messages for Janell 💌
      </h1>
      <p class="text-pink-200/80 text-sm tracking-wider uppercase font-semibold">
        Words of Love & Celebration
      </p>
    </div>

    {/* Messages Grid */}
    <div class="relative z-10 w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-6 pb-12 animate-reveal-up">
      {MESSAGES.map((msg, idx) => (
        <div class={`aero-glass rounded-2xl p-6 border-2 ${msg.color} shadow-lg transition-transform hover:scale-102 hover:-translate-y-1 duration-300 flex flex-col justify-between`}
             style={`background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%); animation-delay: ${idx * 0.15}s;`}>
          <p class="text-white text-base leading-relaxed mb-6 italic" style="font-family: 'Inter', sans-serif;">
            "{msg.text}"
          </p>
          <div class="flex justify-between items-center border-t border-white/10 pt-4 mt-auto">
            <span class="font-extrabold text-white text-lg">{msg.sender}</span>
            <span class="text-xs font-mono px-3 py-1 rounded-full bg-white/10 text-white/70 uppercase">
              {msg.relation}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Application>
