---
import Application from '../../layouts/Application.astro'
import MessageList from '../../components/MessageList/MessageList'
import BackButton from '@/components/Navigator/BackButton'
import Container from '../../layouts/Container.astro'
import { config } from '@/config';

// Keep only 1 message hardcoded on the page (per T-003); the rest come from config (messages.toml) and are openable in the list.
const MESSAGES = [
  {
    sender: "Alice 💖",
    relation: "Best Friend",
    text: "Happy birthday Jell! Hope you have an amazing day filled with love, laughter, and endless sparkles. You deserve the absolute world! ✨",
    color: "border-aero-pink shadow-aero-pink/20",
    gradient: "from-pink-500/20 to-purple-500/20"
  }
];

// Load additional messages from config (toml) for the openable list.
const configMessages = (config as any).messages || [];  // from messages.toml via parser
const displayMessages = [...MESSAGES, ...configMessages];
---

<Application title="For Janell" subTitle=" | Messages">
<Container>

    {/* Floating Back to Home button (solid, type-safe) */}
    <BackButton client:load to="/" label="Back Home" emoji="🏠" />

    <div class="relative z-10 w-full max-w-lg text-center mt-16 mb-6">
      <h1 class="text-3xl font-extrabold text-white mb-2 tracking-wide drop-shadow-md" style="font-family: 'Caveat', cursive;">
        Messages for Janell 💌
      </h1>
      <p class="text-pink-200/80 text-xs tracking-wider uppercase font-extrabold animate-pulse" style="font-family: 'Comfortaa', sans-serif;">
        Words of Love & Celebration
      </p>
    </div>

    {/* Message list component (Client-side with Pretext line measurement and tactile/haptic features). displayMessages = 1 hardcoded + config from toml; openable via the list. */}
    <MessageList client:load messages={displayMessages} />

  <script>
    import { haptic } from '../../utils/haptics';
  </script>
  </Container>
</Application>
