---
import Application from "../layouts/Application.astro";
import ThreeCard from "../components/ThreeCard";
import "../styles/index-page.css";

interface MenuItem {
  name: string;
  href: string;
  emoji: string;
  glowClass: string;
}

interface PageProps {
  title: string;
  subTitle: string;
  welcomeTitle: string;
  welcomeDesc: string;
  menuItems: MenuItem[];
  footer: {
    text: string;
    linkText: string;
    url: string;
  };
}

const pageProps: PageProps = {
  title: "For Janell",
  subTitle: " | Home",
  welcomeTitle: "Hi, Janell!",
  welcomeDesc: "Today is a very special day! We've put together a magical realm of gifts, messages, and surprises just for you. Explore your surprises below! 🫧🔮🎁",
  menuItems: [
    {
      name: "About",
      href: "/about",
      emoji: "📖",
      glowClass: "gc-cyan"
    },
    {
      name: "Gifts",
      href: "/gifts",
      emoji: "🎁",
      glowClass: "gc-pink"
    },
    {
      name: "Messages",
      href: "/messages",
      emoji: "💌",
      glowClass: "gc-purple"
    }
  ],
  footer: {
    text: "Made with ❤️ ",
    linkText: "LOVE-LANG",
    url: "https://love-metalang.xyz"
  }
};
---

<Application title={pageProps.title} subTitle={pageProps.subTitle}>
  <div
    class="relative w-full h-full min-h-screen overflow-hidden flex flex-col items-center justify-between p-4 bg-cover bg-center select-none pb-safe pt-safe"
    style="background-image: url('https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExOHJ2eHY3aTZ2eDFwdnV4amN1ZTZ1Z3R4bnlmdWxlb2p4dmN3dDRuZCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/VxbvpfaTTo3le/giphy.gif');"
  >
    {/* Dark glass tint overlay for readability */}
    <div class="absolute inset-0 bg-gradient-to-b from-blue-950/50 via-cyan-950/20 to-indigo-950/60 pointer-events-none"></div>

    {/* iPhone Maximalist Status Bar */}
    <div class="relative z-20 w-full max-w-lg flex justify-between items-center px-4 py-2 text-white/90 font-semibold text-xs tracking-tight">
      <div id="ios-clock" class="font-bold">12:00</div>
      <div class="flex items-center gap-1 text-[10px]">
        <span>5G</span>
        <span>📶</span>
        <span>🔋 100%</span>
      </div>
    </div>

    {/* Welcome & Widgets Container */}
    <div class="relative z-10 w-full max-w-lg flex-1 flex flex-col justify-center items-center gap-5 px-2 my-auto">
      {/* Glowing glass welcome header */}
      <div class="aero-glass rounded-3xl p-5 text-white w-full border-white/20 animate-reveal-up text-center shadow-[0_8px_32px_rgba(255,102,196,0.15)]">
        <h1
          class="text-4xl font-extrabold mb-1 tracking-tight drop-shadow-md text-glow"
          style="font-family: 'Caveat', cursive;"
        >
          {pageProps.welcomeTitle}
        </h1>
        <p class="text-xs text-blue-100/90 leading-relaxed font-medium" style="font-family: 'Patrick Hand', cursive;">
          {pageProps.welcomeDesc}
        </p>
      </div>

      {/* Large 3D Greeting Card Container */}
      <div class="w-full animate-reveal-up" style="animation-delay: 0.1s;">
        <ThreeCard client:load />
      </div>

      {/* Globular menu options (Refactored to 3 columns) */}
      <div
        class="grid grid-cols-3 gap-4 w-full mt-2 animate-reveal-up"
        style="animation-delay: 0.2s;"
      >
        {pageProps.menuItems.map((item) => (
          <a
            href={item.href}
            class="bubble-menu-item relative flex flex-col items-center group cursor-pointer"
          >
            <div class={`globular-circle ${item.glowClass} w-16 h-16 md:w-20 md:h-20`}>
              <span class="text-2xl md:text-3xl group-hover:scale-115 transition-transform duration-300">{item.emoji}</span>
              <div class="globular-gloss"></div>
            </div>
            <span class="bubble-label text-[10px] md:text-xs">{item.name}</span>
          </a>
        ))}
      </div>
    </div>

    {/* Fullscreen Zoom Transition Overlay */}
    <div
      id="zoom-overlay"
      class="fixed inset-0 z-50 pointer-events-none opacity-0 scale-0 origin-center"
    >
    </div>

    {/* Cute Tiny Footer */}
    <footer class="relative z-20 w-full text-center py-2 text-[11px] text-white/60 tracking-wider font-semibold" style="font-family: 'Comfortaa', sans-serif;">
      {pageProps.footer.text}
      <a 
        href={pageProps.footer.url} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-aero-cyan hover:text-aero-pink hover:underline transition-colors active:scale-95 inline-block font-extrabold"
        id="footer-link"
      >
        {pageProps.footer.linkText}
      </a>
    </footer>

    {/* Micro bottom navigation bar indicator (iPhone Home Indicator simulation) */}
    <div class="relative z-20 w-32 h-1 bg-white/40 rounded-full mx-auto mb-2 pointer-events-none"></div>
  </div>
</Application>

<script>
  import { haptic } from '../utils/haptics';

  // ─── Real-time iOS Digital Clock ─────────────────────────
  const updateClock = () => {
    const clockEl = document.getElementById('ios-clock');
    if (!clockEl) return;
    const now = new Date();
    let hours = now.getHours();
    const minutes = now.getMinutes().toString().padStart(2, '0');
    const ampm = hours >= 12 ? 'PM' : 'AM';
    hours = hours % 12 || 12; // 12-hour format
    clockEl.textContent = `${hours}:${minutes} ${ampm}`;
  };
  updateClock();
  setInterval(updateClock, 30000);

  // ─── Touch Particle Generator ────────────────────────────
  let lastMove = 0;
  const generateBubble = (clientX: number, clientY: number) => {
    const now = Date.now();
    if (now - lastMove < 35) return;
    lastMove = now;

    const bubble = document.createElement("div");
    bubble.className = "mouse-bubble";

    const size = Math.random() * 18 + 8;
    bubble.style.width = `${size}px`;
    bubble.style.height = `${size}px`;
    bubble.style.left = `${clientX - size / 2}px`;
    bubble.style.top = `${clientY - size / 2}px`;

    const dx = (Math.random() - 0.5) * 60;
    const dy = (Math.random() - 0.5) * 60 - 60;
    bubble.style.setProperty("--dx", `${dx}px`);
    bubble.style.setProperty("--dy", `${dy}px`);

    document.body.appendChild(bubble);
    setTimeout(() => bubble.remove(), 1200);
  };

  document.addEventListener("mousemove", (e) => generateBubble(e.clientX, e.clientY));
  document.addEventListener("touchmove", (e) => {
    if (e.touches && e.touches[0]) {
      generateBubble(e.touches[0].clientX, e.touches[0].clientY);
    }
  });

  // ─── Footer Link Haptics ─────────────────────────────────
  const footerLink = document.getElementById('footer-link');
  if (footerLink) {
    footerLink.addEventListener('pointerdown', () => {
      haptic.trigger('light');
    });
  }

  // ─── Bubble Touch & Click Navigation ─────────────────────
  const overlay = document.getElementById("zoom-overlay") as HTMLDivElement;
  const items = document.querySelectorAll(".bubble-menu-item");

  items.forEach((item) => {
    // Trigger haptics instantly on pointerdown
    item.addEventListener("pointerdown", () => {
      haptic.trigger('success');
    });

    item.addEventListener("click", (e) => {
      e.preventDefault();
      const href = item.getAttribute("href");
      if (!href) return;
      const rect = item.getBoundingClientRect();
      const bubble = item.querySelector(".globular-circle") as HTMLDivElement;
      const bg = window.getComputedStyle(bubble).background;

      // Sound pop feedback
      const audioPop = new Audio("/resources/sfx/blast.mp3");
      audioPop.volume = 0.4;
      audioPop.play().catch(() => {});

      // Position overlay at bubble center
      overlay.style.background = bg;
      overlay.style.left = `${rect.left + rect.width / 2}px`;
      overlay.style.top = `${rect.top + rect.height / 2}px`;
      overlay.style.width = "10px";
      overlay.style.height = "10px";
      overlay.style.marginLeft = "-5px";
      overlay.style.marginTop = "-5px";
      overlay.style.borderRadius = "50%";
      overlay.style.transform = "scale(0)";
      overlay.style.opacity = "1";
      overlay.style.transition = "none";

      // Force reflow
      void overlay.offsetWidth;

      // Zoom transition animation
      overlay.style.transition = "transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.55s ease";
      overlay.style.transform = "scale(300)";

      setTimeout(() => {
        window.location.href = href;
      }, 500);
    });
  });
</script>
