---
import Application from '@/layouts/Application.astro'
import FrutigerScenes from '@/components/FrutigerScenes'
import { APP_CONFIG } from '@/config'
---

<Application title="For Janell" subTitle=" | Gift 2026">
  <div class="relative w-full h-screen overflow-hidden flex flex-col justify-between pb-safe pt-safe">
    {/* Floating Back to Vault button */}
    <a href="/gifts" id="back-vault-btn" class="absolute top-4 left-4 z-50 flex items-center gap-2 px-4 py-2 rounded-full aero-glass text-white font-bold text-sm transition-transform hover:scale-105 active:scale-95">
      🎁 Gift Vault
    </a>
    
    <div class="flex-1 w-full relative">
      <FrutigerScenes client:load {...APP_CONFIG} />
    </div>
  </div>

  <script>
    import { haptic } from '../../../utils/haptics';
    const backBtn = document.getElementById('back-vault-btn');
    if (backBtn) {
      backBtn.addEventListener('pointerdown', () => haptic.trigger('light'));
    }
  </script>
</Application>
