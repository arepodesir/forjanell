---
let { title = "", subTitle= "" } = Astro.props 
---
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />

    <meta name="theme-color" content="#ff66c4" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/resources/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/resources/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/resources/favicon/favicon-16x16.png" />

    <title>{title}{subTitle}</title>
    <meta name="description" content="A holographic birthday card experience by Hadacard" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;600;700&family=Caveat:wght@400;700&family=Patrick+Hand&family=Inter:wght@400;600;700&family=Outfit:wght@600;700;800;900&family=Great+Vibes&family=Alex+Brush&display=swap" rel="stylesheet" />
  </head>